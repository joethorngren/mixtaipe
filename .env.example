# Convex (populated by `npx convex dev` on first run)
NEXT_PUBLIC_CONVEX_URL=
CONVEX_DEPLOYMENT=

# Optional: the Convex HTTP URL (shown on /developers as the API base).
# If unset, the UI derives it from NEXT_PUBLIC_CONVEX_URL by swapping the
# `.convex.cloud` suffix for `.convex.site`.
NEXT_PUBLIC_CONVEX_SITE_URL=

# Google AI (Gemini + Lyria) — from https://aistudio.google.com/app/apikey
GOOGLE_AI_API_KEY=

# Optional: Vertex AI if we need Lyria via Vertex instead of AI Studio
GOOGLE_CLOUD_PROJECT=
GOOGLE_APPLICATION_CREDENTIALS=
