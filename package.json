{
  "name": "mixtaipe",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "convex": "convex dev",
    "convex:push": "convex dev --once",
    "convex:typecheck": "tsc -p convex/tsconfig.json",
    "trends:google": "node scripts/google-trends.mjs",
    "trends:google:refresh": "convex run --prod trends:refreshGoogleTrends '{\"geo\":\"US\",\"limit\":10}'",
    "trends:google:import": "node scripts/google-trends.mjs --import --prod --replace --limit 10",
    "test:e2e": "playwright test",
    "test:e2e:install": "playwright install chromium"
  },
  "dependencies": {
    "convex": "^1.17.4",
    "next": "16.2.4",
    "react": "19.2.5",
    "react-dom": "19.2.5"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/node": "^22.10.7",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.5.1",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.3"
  }
}
